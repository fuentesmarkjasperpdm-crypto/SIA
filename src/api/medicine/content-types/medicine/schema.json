{
  "kind": "collectionType",
  "collectionName": "medicines",
  "info": {
    "singularName": "medicine",
    "pluralName": "medicines",
    "displayName": "Medicine"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "BrandName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "required": true
    },
    "GenericName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "required": true
    },
    "DosageForm": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Tablet",
        "Syrup",
        "Capsule",
        "Injectable"
      ]
    },
    "Manufacturer": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "Strength": {
      "type": "decimal",
      "min": 0
    },
    "Stock": {
      "type": "component",
      "component": "inventory.stock-inventory",
      "repeatable": true
    },
    "medicine_category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::medicine-category.medicine-category",
      "inversedBy": "medicines"
    },
    "purchase_order_lines": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::purchase-order-line.purchase-order-line",
      "mappedBy": "medicine"
    }
  }
}
