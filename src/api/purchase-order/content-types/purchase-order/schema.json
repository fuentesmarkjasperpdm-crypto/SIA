{
  "kind": "collectionType",
  "collectionName": "purchase_orders",
  "info": {
    "singularName": "purchase-order",
    "pluralName": "purchase-orders",
    "displayName": "Purchase Order"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "OrdateDate": {
      "type": "datetime",
      "required": true
    },
    "TotalAmount": {
      "type": "decimal",
      "required": true,
      "default": 0
    },
    "PaymentStatus": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Pending",
        "Received",
        "Cancelled"
      ]
    },
    "ReceivedDate": {
      "type": "datetime",
      "required": false
    },
    "purchase_order_lines": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::purchase-order-line.purchase-order-line",
      "inversedBy": "purchase_orders"
    },
    "supplier": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::supplier.supplier",
      "inversedBy": "purchase_orders"
    }
  }
}
